/                      ext4     /dev/block/bootdevice/by-name/system       flags=display=;slotselect
/vendor                ext4     /dev/block/bootdevice/by-name/vendor       flags=display=vendor;slotselect
/data                  f2fs     /dev/block/bootdevice/by-name/userdata     flags=display=data;encryptable=footer
/mnt/vendor/pstore     ext4     /dev/block/bootdevice/by-name/sysprop      flags=display=pstore
/mnt/vendor/persist    ext4     /dev/block/bootdevice/by-name/persist      flags=display=persist
/sdcard                vfat     /dev/block/mmcblk1p1                       flags=display=sdcard
/boot                  emmc     /dev/block/bootdevice/by-name/boot         flags=display=boot
/misc                  emmc     /dev/block/bootdevice/by-name/misc         flags=display=misc
